# Database — pick one:
# PostgreSQL (default, requires Docker):
#   DATABASE_URL=postgresql://boltalka:boltalka@localhost:5432/boltalka
# SQLite (lightweight, no Docker needed):
#   DATABASE_URL=file:./dev.db

DATABASE_URL=file:./dev.db

JWT_SECRET=dev-secret-change-in-production
# REDIS_URL=redis://localhost:6379
PORT=4000

# TURN server for WebRTC calls (required for mobile)
# Set a random secret; coturn uses it to validate time-limited credentials.
# TURN_SECRET=change-me-in-production
# TURN_URL=turn:localhost:3478

# Protocol for file upload URLs (https by default)
# Set to "http" when testing without TLS termination.
# URL_PROTOCOL=http

# VAPID keys for Web Push notifications (PWA)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
